# Neon Postgres connection string (required — filesystem fallback was removed in PR 1 of the multi-user series)
# Get this from your Neon dashboard: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# --- Multi-user seeding (required to run `npm run db:migrate`) ---
# These passwords are bcrypt-hashed and stored in the `users` table.
# Set in .env.local for local migrations AND as GitHub repo secrets for CI.
# Pick strong values; you can rotate them later by re-seeding or via the UI in PR 2.
ADMIN_INITIAL_PASSWORD=
DEMO_USER_PASSWORD=
TEST_USER_PASSWORD=

# ai-task-list integration
AI_TASK_LIST_URL=https://tasklistai.vercel.app
AI_TASK_LIST_API_KEY=
NEXT_PUBLIC_AI_TASK_LIST_URL=https://tasklistai.vercel.app

# Monarch Money integration (real financial data)
# Run `npx tsx scripts/monarch-login.ts` to obtain a session token
MONARCH_TOKEN=

# Two-way task sync (local OpenClaw <-> production dashboard)
# SYNC_API_KEY protects the /api/sync-tasks endpoint
SYNC_API_KEY=
# DASHBOARD_URL is used by the MCP server to reach the production API
DASHBOARD_URL=

# Garmin Connect integration (required for live sync from dashboard)
GARMIN_EMAIL=
GARMIN_PASSWORD=
