# Neon Postgres connection string (required for persistent storage on Vercel)
# Get this from your Neon dashboard: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Optional: Override workspace path for local development
# WORKSPACE_PATH=/Users/you/.openclaw/workspace

# ai-task-list integration
AI_TASK_LIST_URL=https://tasklistai.vercel.app
AI_TASK_LIST_API_KEY=
NEXT_PUBLIC_AI_TASK_LIST_URL=https://tasklistai.vercel.app

# Monarch Money integration (real financial data)
# Run `npx tsx scripts/monarch-login.ts` to obtain a session token
MONARCH_TOKEN=

# Two-way task sync (local OpenClaw <-> production dashboard)
# SYNC_API_KEY protects the /api/sync-tasks endpoint
SYNC_API_KEY=
# DASHBOARD_URL is used by the MCP server to reach the production API
DASHBOARD_URL=
